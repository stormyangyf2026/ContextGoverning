# Context Platform — Production Environment Variables
# T11.8: Deployment Scripts

# PostgreSQL
POSTGRES_USER=context_platform
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=context_platform
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=8000
ADMIN_PORT=3001
USER_PORT=3002

# Security (MUST CHANGE IN PRODUCTION)
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# Rate Limiting
RATE_LIMIT_DEFAULT=600 per minute

# Embedding
EMBEDDING_DIMENSION=1024

# Dedup
DEDUP_SIMILARITY_THRESHOLD=0.85

# LLM (DeepSeek)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Qdrant (for Mem0)
QDRANT_URL=http://qdrant:6333

# Logging
LOG_LEVEL=INFO

# Frontend API Base URL
VITE_API_BASE_URL=http://backend:8000
