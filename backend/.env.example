# ============================================================
# Context Platform - Environment Variables
# Copy this to .env and fill in your values.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://context_platform:context_platform_dev@localhost:5432/context_platform
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant (Mem0) ---
QDRANT_URL=http://localhost:6333

# --- LLM ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# --- Embedding (BGE-M3) ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=600 per minute
RATE_LIMIT_HOURLY=10000 per hour

# --- Deduplication ---
DEDUP_SIMILARITY_THRESHOLD=0.85

# --- Confidence Engine — Time-based Decay ---
CONFIDENCE_DECAY_START_MONTHS=6.0
CONFIDENCE_DECAY_RATE_PER_MONTH=0.03
CONFIDENCE_DECAY_MIN_SCORE=0.20

# --- Confidence Engine — Multi-source Corroboration ---
CONFIDENCE_CORROBORATION_MAX_BOOST=0.45

# --- Confidence Engine — Contradiction ---
CONFIDENCE_CONFLICT_PENALTY=0.10

# --- Confidence Engine — Review Upgrade ---
CONFIDENCE_REVIEW_UPGRADE_LEVEL=L3
CONFIDENCE_REVIEW_UPGRADE_SCORE=0.78

# --- Conflict Detection ---
CONFLICT_SIMILARITY_THRESHOLD=0.75

# --- Lifecycle Management ---
LIFECYCLE_AUTO_DECAY_MONTHS=6

# --- External Integration Timeouts ---
FEISHU_API_TIMEOUT=30.0
FEISHU_BOT_TIMEOUT=10.0
IMA_API_TIMEOUT=30.0
EMAIL_FETCH_MAX=50
EMAIL_FETCH_DAYS=7

# --- External Integrations ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_WEBHOOK=
IMA_API_KEY=
IMA_BASE_URL=
STOCK_DATA_API_KEY=
STOCK_DATA_BASE_URL=
EMAIL_IMAP_HOST=
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=

# --- Configuration Sections (comma-separated, for config_service) ---
CONFIG_VALID_SECTIONS=confidence_engine,ingestion,search,llm,security,lifecycle,notification,export,integration,embedding

# --- Sub-component config path ---
CONTEXT_PLATFORM_CONFIG_PATH=

# --- Logging ---
LOG_LEVEL=INFO
